[Unit]
Description=RemoteUSB Watchdog (WLAN + WireGuard Überwachung)
After=network-online.target remoteusb-gpio.service
Wants=network-online.target remoteusb-gpio.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/bin/remoteusb-watchdog.py
Restart=always
RestartSec=5
EnvironmentFile=/etc/remoteusb/watchdog.env

[Install]
WantedBy=multi-user.target
