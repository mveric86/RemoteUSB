#!/bin/bash
# =============================================================================
# remoteusb – USB/IP Client Wrapper
#
# Listet, attached, detached USB-Geräte von einem RemoteUSB-Server mit
# automatischem Detach bei Script-Exit (Trap auf SIGINT/SIGTERM/EXIT).
#
# Installation (einmal pro Client):
#   sudo apt install usbip         # Debian
#   # oder: sudo apt install linux-tools-generic hwdata
#   sudo modprobe vhci-hcd
#   echo vhci-hcd | sudo tee /etc/modules-load.d/vhci-hcd.conf
#   sudo curl -o /usr/local/bin/remoteusb \
#        https://raw.githubusercontent.com/mveric86/RemoteUSB/master/client/remoteusb
#   sudo chmod +x /usr/local/bin/remoteusb
#
# Nutzung:
#   remoteusb <host>                  – verfügbare Geräte anzeigen
#   remoteusb <host> <match>          – Gerät per Index/busid/Name-Substring
#                                       attachen und Session halten bis Ctrl-C
#   remoteusb <host> --list           – nur Liste, gleich wie ohne match
#   remoteusb --detach-all            – alle eigenen Sessions detachen
#
# Beispiele:
#   remoteusb pi.lan                  – Liste
#   remoteusb pi.lan flipper          – erstes Gerät dessen Name 'flipper'
#                                       enthält (case-insensitive)
#   remoteusb pi.lan 1-1.4            – per busid
#   remoteusb pi.lan 1                – per Index aus der Liste
# =============================================================================

set -e

usage() {
    cat >&2 <<EOF
Usage:
  remoteusb <host>                  List available devices
  remoteusb <host> <match>          Attach device (index / busid / name substring),
                                    hold session until Ctrl-C, then detach
  remoteusb --detach-all            Detach all local USB/IP sessions
EOF
    exit 2
}

USBIP="$(command -v usbip || true)"
if [ -z "$USBIP" ]; then
    # Debian-Paket 'usbip' vs. Ubuntu linux-tools Pfad
    USBIP="$(ls /usr/lib/linux-tools/*/usbip 2>/dev/null | head -1 || true)"
fi
if [ -z "$USBIP" ]; then
    echo "error: 'usbip' not found. Install package 'usbip' (Debian) or" >&2
    echo "       'linux-tools-generic' (Ubuntu)." >&2
    exit 3
fi

# ---------------------------------------------------------------------------
# Modes
# ---------------------------------------------------------------------------
if [ "$1" = "--detach-all" ] || [ "$1" = "-d" ]; then
    ports=$("$USBIP" port 2>/dev/null | awk '/^Port/ {gsub(":",""); print $2}')
    if [ -z "$ports" ]; then
        echo "No attached sessions."
        exit 0
    fi
    for p in $ports; do
        echo "[detach] port $p"
        sudo "$USBIP" detach -p "$p" || true
    done
    exit 0
fi

[ $# -lt 1 ] && usage
HOST="$1"
MATCH="${2:-}"

# ---------------------------------------------------------------------------
# Parse `usbip list -r <host>` into array lines "busid|vid:pid|name"
# ---------------------------------------------------------------------------
list_output=$("$USBIP" list -r "$HOST" 2>&1) || {
    echo "error: cannot list devices on $HOST" >&2
    echo "$list_output" >&2
    exit 4
}

declare -a ENTRIES
current_busid=""; current_vidpid=""; current_name=""
re_busid='^[[:space:]]*-[[:space:]]busid[[:space:]]+([^ ]+)[[:space:]]+\(([^)]+)\)'
re_name='^[[:space:]]+[^:]+:[[:space:]]+(.+)$'
while IFS= read -r line; do
    if [[ "$line" =~ $re_busid ]]; then
        if [ -n "$current_busid" ]; then
            ENTRIES+=("$current_busid|$current_vidpid|$current_name")
        fi
        current_busid="${BASH_REMATCH[1]}"
        current_vidpid="${BASH_REMATCH[2]}"
        current_name=""
    elif [ -n "$current_busid" ] && [[ "$line" =~ $re_name ]]; then
        [ -z "$current_name" ] && current_name="${BASH_REMATCH[1]}"
    fi
done <<< "$list_output"
[ -n "$current_busid" ] && ENTRIES+=("$current_busid|$current_vidpid|$current_name")

if [ ${#ENTRIES[@]} -eq 0 ]; then
    echo "No exportable devices on $HOST."
    exit 0
fi

# ---------------------------------------------------------------------------
# List mode (no match / explicit --list)
# ---------------------------------------------------------------------------
if [ -z "$MATCH" ] || [ "$MATCH" = "--list" ] || [ "$MATCH" = "-l" ]; then
    echo "Exportable devices on $HOST:"
    i=0
    for e in "${ENTRIES[@]}"; do
        i=$((i+1))
        IFS='|' read -r busid vidpid name <<< "$e"
        printf "  [%d]  %-10s  %s  (%s)\n" "$i" "$busid" "$name" "$vidpid"
    done
    exit 0
fi

# ---------------------------------------------------------------------------
# Match mode: resolve MATCH to a busid
# ---------------------------------------------------------------------------
resolve_busid() {
    local match="$1"
    # Index?
    if [[ "$match" =~ ^[0-9]+$ ]]; then
        local idx=$((match - 1))
        if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#ENTRIES[@]}" ]; then
            IFS='|' read -r b _ _ <<< "${ENTRIES[$idx]}"
            echo "$b"; return
        fi
    fi
    # Exakte busid?
    for e in "${ENTRIES[@]}"; do
        IFS='|' read -r b _ _ <<< "$e"
        if [ "$b" = "$match" ]; then
            echo "$b"; return
        fi
    done
    # Name-Substring (case-insensitive)
    local lower_match
    lower_match=$(echo "$match" | tr '[:upper:]' '[:lower:]')
    for e in "${ENTRIES[@]}"; do
        IFS='|' read -r b vp n <<< "$e"
        local lower_name
        lower_name=$(echo "$n $vp" | tr '[:upper:]' '[:lower:]')
        if [[ "$lower_name" == *"$lower_match"* ]]; then
            echo "$b"; return
        fi
    done
    return 1
}

BUSID=$(resolve_busid "$MATCH") || {
    echo "error: no device matching '$MATCH' on $HOST. Available:" >&2
    for e in "${ENTRIES[@]}"; do
        IFS='|' read -r b vp n <<< "$e"
        echo "  $b  $n ($vp)" >&2
    done
    exit 5
}

# Passende Metadaten für die Status-Ausgabe
DEV_NAME="?"; DEV_VID="?"
for e in "${ENTRIES[@]}"; do
    IFS='|' read -r b vp n <<< "$e"
    if [ "$b" = "$BUSID" ]; then DEV_NAME="$n"; DEV_VID="$vp"; fi
done

# ---------------------------------------------------------------------------
# Attach mit Auto-Detach-Trap
# ---------------------------------------------------------------------------
echo "[attach] $DEV_NAME ($DEV_VID) busid=$BUSID from $HOST"
sudo "$USBIP" attach -r "$HOST" -b "$BUSID"

# Gerade attachten Port finden
ATTACHED_PORT=$(sudo "$USBIP" port 2>/dev/null | awk -v id="$BUSID" '
    /^Port/ { port=$2; sub(":","",port) }
    $0 ~ id { print port; exit }')

cleanup() {
    if [ -n "$ATTACHED_PORT" ]; then
        echo
        echo "[detach] port $ATTACHED_PORT"
        sudo "$USBIP" detach -p "$ATTACHED_PORT" >/dev/null 2>&1 || true
    fi
}
trap cleanup EXIT INT TERM

echo "[ok] attached. Press Ctrl-C to detach."
# Blockieren bis Signal
while sleep 3600; do :; done
